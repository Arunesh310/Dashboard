rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isShadowfaxUser() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('(?i)^.+@shadowfax[.]in$');
    }

    match /dashboard_snapshot/{docId} {
      allow read, write: if isShadowfaxUser();
    }
    match /dashboard_snapshot_chunks/{docId} {
      allow read, write: if isShadowfaxUser();
    }
  }
}
