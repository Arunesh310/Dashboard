# Optional: shared CSV snapshot (Firebase / Firestore). Copy to .env and fill in.
# Firebase console → Project settings → Your apps → Web app → Firebase SDK snippet (config object).
#
# Site access: set to true so only @shadowfax.in users can open the app (Firebase Email/Password required).
# `npm run dev` always skips this gate so you can work locally even when this is true.
# Publish firestore.rules in Console (rules expect signed-in @shadowfax.in). Never put Admin SDK keys in Vite.
VITE_SHADOWFAX_AUTH=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
