# Optional: shared CSV snapshot (Firebase / Firestore). Copy to .env and fill in.
# Firebase console → Project settings → Your apps → Web app → Firebase SDK snippet (config object).
#
# Deploy rules: firebase deploy --only firestore:rules (or paste firestore.rules in Firestore → Rules).
# Current rules do not require Authentication — only this collection is open. Never put Admin SDK keys in Vite.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
