# Optional: shared CSV snapshot (Supabase). Copy to .env and fill in.
# Create a project at https://supabase.com, run supabase/schema.sql, then paste URL + anon key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: one-time DB migration for Camera Status columns (npm run migrate:camera).
# Supabase → Project Settings → Database → Connection string → URI (include password).
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
